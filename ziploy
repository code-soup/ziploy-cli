#!/bin/bash

# Default files to ignore
# Files we don't want to upload to remote server
ignoreArray=('*.swp' '.ziployignore' '*.git*' 'ziploy' 'node_modules/*' '__to-ziploy/' '__to-ziploy')


# Ziploy Ignore custom file
ignoreList='.ziployignore'

# Ziploy file name, without extension
zipFilename='_ziploy.zip'

ziployId="${1}"
ziploySecret="${2}"
ziployEndpoint=$(echo "$3" | xargs)
ziployEndpoint="${ziployEndpoint%/}/wp-json/ziploy/v1/update"
ziployTargetDir="__to-ziploy"


# Remove zipped file if alreay exists
if [[ -f $zipFilename ]]; then
    rm -rf "${zipFilename}"
    echo "Cleaning repository cache"
    sleep 1
fi

# Delete folder with chunks
if [ -d $ziployTargetDir ]; then
    rm -rf "${ziployTargetDir}"
fi

# Update ignore list from .ziployignore
if [[ -f "$ignoreList" ]]; then
    
    echo "Generating ignore list"
    sleep 1
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        
        # Trim whitespace from both ends
        line=$(echo "$line" | xargs)
        
        # Skip empty lines and lines starting with a comment (#)
        [[ -z "$line" || "$line" == \#* ]] && continue
        
        # Append '*' if line ends with '/'
        if [[ "$line" == */ ]]; then
            line="${line}*"
        fi
        
        # Append to ignore list
        ignoreArray+=("$line")

    done < "$ignoreList"
fi

# Zip everything
echo "Preparing files for ziploy"
sleep 1

# Create directory for chunked zip files
mkdir "$ziployTargetDir";
sleep 1


# Create a single zip file
zipFile="${ziployTargetDir}/${zipFilename}"
zip -qq -r "${zipFile}" . -x "${ignoreArray[@]}"

# Split the zip file into 10MB chunks.
# This will create files like archive.zip.aa, archive.zip.ab, etc.
split -b 10m "${zipFile}" "${zipFile}."

# Remove single zipped file
if [[ -f $zipFile ]]; then
    rm -rf "${zipFile}"
fi

# Rename the split files to have numeric suffixes (.01, .02, etc.)
i=1
for f in "${zipFile}."*; do
    new=$(printf "%s.z%02d" "$zipFile" "$i")
    mv "$f" "$new"
    i=$((i + 1))
done

if [ -d "$ziployTargetDir" ]; then
    echo "Uploading files from $ziployTargetDir to remote server"
    total=$(find "$ziployTargetDir" -type f | wc -l)
    current=0
    find "$ziployTargetDir" -type f -print0 | while IFS= read -r -d '' file; do
        current=$((current + 1))
        response=$(curl -L -X POST "${ziployEndpoint}" \
            -H "cache-control: no-cache" \
            -F "ziploy=@${file}" \
            -F "id=${ziployId}" \
            -F "secret=${ziploySecret}" \
            -F "current=${current}" \
            -F "total=${total}")
        echo -e "\033[0;32mRemote\033[0m: $response"
    done
else
    echo "Directory ${ziployTargetDir} does not exist."
fi

sleep 1

# Remove zipped file if alreay exists
if [[ -d $ziployTargetDir ]]; then
    rm -rf "${ziployTargetDir}"
fi

echo "All tasks completed"